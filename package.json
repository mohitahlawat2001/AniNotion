{
  "name": "aninotion-app",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd aninotion-backend && npm run dev",
    "client": "cd aninotion-frontend && npm run dev",
    "seed": "cd aninotion-backend && node scripts/seedCategories.js",
    "prepare": "husky install",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "@eslint/js": "^10.0.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
